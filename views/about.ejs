<%- include('partials/header', { title: 'Sobre' }) %>

<style>
body {
  background-attachment: fixed;
  background-size: cover;
  background-position: center;
  min-height: 100vh;
  margin: 0;
  padding: 0;
}

.titulo-principal {
  color: #564787;
  font-size: 40px;
  font-family: "Stencil Std", "Stencil", fantasy;
  letter-spacing: 1px;
  padding: 20px;
  padding-left: 1px;
  padding-top: 25px;
  box-sizing: border-box;
  text-align: center;
  margin-top: -30px;
}

.titulo-final {
  color: #564787;
  font-size: 40px;
  font-family: "Stencil Std", "Stencil", fantasy;
  letter-spacing: 1px;
  padding: 20px;
  padding-left: 1px;
  padding-top: 25px;
  box-sizing: border-box;
  text-align: center;
  margin-top: 5px;
}

h2 {
  font-family: 'Georgia', serif;
  color: #00bd1f;
  font-size: 28px;
  margin-top: 0;
  margin-bottom: 20px;
  text-align: center;
}

p{
  font-family: 'Georgia', serif;
  color: #564787;
  max-width: 700px;
  margin: 10px auto;
  line-height: 1.5;
  font-size: 18px;
  font-weight: bold;
  text-align: justify;

}

.bloco,
