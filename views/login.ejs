<%- include('partials/header', { title: 'Login' }) %>

<style>
body {
  background-attachment: fixed;
  background-size: cover;
  background-position: center;
  min-height: 100vh;
  margin: 0;
  padding: 0;
}

.titulo-principal {
  color: #564787;
  font-size: 30px;
  font-family: "Stencil Std", "Stencil", fantasy;
  letter-spacing: 1px;
  padding: 20px;
  padding-left: 1px;
  padding-top: 30px;
  padding-bottom: -30px;
  box-sizing: border-box;
  text-align: center;
}

h2 {
  font-family: 'Georgia', serif;
  color: #564787;
  font-size: 28px;
  margin-top: 0;
  margin-bottom: 20px;
  text-align: center;
}

p{
  font-family: 'Georgia', serif;
  color: #564787;
  margin: 10px auto;
  margin-top: 22px;
  line-height: 1.5;
  font-size: 18px;
  font-weight: bold;
  text-align: left;
  max-width: 100%;
}

.bloco {
  width: 100%;
  max-width: 400px;
  margin: 0 auto;
  background-color: #ad9fdd;
  align-items: flex-start;
  border-radius: 8px;
  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
  padding-top: 10px;
  margin-top: -30px;
  padding: 3px 5px;
  gap: 20px;
  justify-content: center;
  align-items: center;
  text-align: center; 
}

.home {
  min-height: auto;
}

#loginForm {
  background: #ad9fdd; 
  padding: 40px;
  border-radius: 8px;
  width: 100%;
  max-width: 400px; 
  margin: 30px auto 100px auto; 
  box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  display: flex;
  flex-direction: column;
  gap: 20px;
  box-sizing: border-box;
  font-family: 'Georgia', serif;
}

#loginForm input {
  width: 100%;
  padding: 15px;
  border: 1px solid #564787;
  border-radius: 8px;
  font-size: 16px;
  box-sizing: border-box;
  transition: border-color 0.3s ease;
  font-family: 'Georgia', serif;
}

#loginForm input:focus {
  border-color: #564787;
  outline: none;
}

#loginForm button {
  padding: 15px 25px;
  border: none;
  border-radius: 8px;
  color: #efeaff ; 
  font-size: 18px;
  cursor: pointer;
  background-color: #564787;
  font-weight: bold;
  transition: background 0.2s ease;
  font-family: 'Georgia', serif;
}

#loginForm button:hover {
  background-color: #33255f;
}

.form-footer {
  text-align: center;
  margin-top: 10px;
  font-size: 16px;
  color: #564787;
  font-weight: bold;
}

.form-footer a {
  color: #33255f;
  text-decoration: none;
  transition: color 0.2s;
}

.form-footer a:hover {
  color: #564787;
  text-decoration: underline;
}
</style>

<div class="main-content">
    <div class="bloco">
        <h2 class="titulo-principal">Entrar na conta</h2>
    </div>
    
    <form id="loginForm">
      <input
      type="email"
      id="email"
      placeholder="Email"
      required
    />
    
    <input
      type="password"
      id="senha"
      placeholder="Senha"
      required
    />
    
    <button type="submit">
      Entrar
    </button>
    
    <div class="form-footer">
      Não tem uma conta? <a href="/signup">Cadastre-se aqui</a>
    </div>
  </form>
</div>

<script>
document.getElementById("loginForm").addEventListener("submit", async (e) => {
    e.preventDefault();
    const email = document.getElementById("email").value;
    const senha = document.getElementById("senha").value;

    try {
        const resposta = await fetch("/auth/login", {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify({ email, senha })
        });

        const data = await resposta.json();
        if (resposta.ok) {
            localStorage.setItem("usuario", JSON.stringify(data.usuario));
            alert("Login realizado!");
            window.location.replace("/profile");
        } else {
            alert(data.msg || "Erro ao fazer login");
        }

    } catch (erro) {
        console.log(erro);
        alert("Erro ao fazer login");
    }
});
</script>

<%- include('partials/footer') -%>