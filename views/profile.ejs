<%- include('partials/header', { title: 'Meu Perfil' }) %>

<style>
  body {
  background-attachment: fixed;
  background-size: cover;
  background-position: center;
  min-height: 100vh;
  margin: 0;
  padding: 0;
}
 
  .perfil-container {
    background: #ad9fdd;
    max-width: 550px;
    margin: 60px auto 100px auto;
    padding: 40px;
    border-radius: 25px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    text-align: center;
    box-sizing: border-box;
  }

  .perfil-container h1 {
    font-family: 'Georgia', serif;
    color: #564787;
    font-size: 32px;
    margin-top: 0;
    margin-bottom: 20px;
  }

  .avatar-container {
    margin-bottom: 15px;
    position: relative;
    display: inline-block;
  }

  .avatar-preview {
    width: 130px;
    height: 130px;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid #ad9fdd;
    box-shadow: 0 4px 10px rgba(0,0,0,0.15);
    background-color: #ad9fdd;
  }

  #foto-form {
    padding: 15px 25px;
    border: none;
    border-radius: 8px;
    color: #efeaff ; 
    font-size: 18px;
    cursor: pointer;
    background-color: #564787;
    font-weight: bold;
    transition: background 0.2s ease;
    font-family: 'Georgia', serif;
  }

  /*#loginForm button:hover {
  background-color: #33255f;
}*/

  #input-file-foto {
    display: none;
  }

  .label-upload {
    padding: 15px 25px;
    border: none;
    border-radius: 8px;
    color: #efeaff ; 
    font-size: 18px;
    cursor: pointer;
    background-color: #564787;
    font-weight: bold;
    transition: background 0.2s ease;
    font-family: 'Georgia', serif;
  }

  .label-upload:hover {
    background: #002d66;
  }

  .label-upload:active {
    transform: scale(0.98);
  }

  /* --- Caixas de Informação --- */
  .info-box {
    background: #ffffff;
    padding: 15px 20px;
    border: 1px solid #dfefff;
    border-radius: 12px;
    margin-bottom: 15px;
    text-align: left;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  }

  .info-box p {
    margin: 0;
    font-size: 16px;
    color: #333;
  }

  .info-box strong {
    color: #104488;
  }

  /* --- Botões de Ação (Voltar e Sair) --- */
  .btn-voltar {
    display: inline-block;
    margin-top: 20px;
    padding: 12px 30px;
    border: none;
    border-radius: 8px;
    background-color: #007bff;
    color: white;
    font-size: 16px;
    font-weight: bold;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.2s;
  }

  .btn-voltar:hover {
    background-color: #0056b3;
  }

  .btn-logout {
    display: inline-block;
    margin-top: 20px;
    margin-left: 10px;
    padding: 12px 30px;
    border: 2px solid #e74c3c;
    border-radius: 8px;
    background-color: transparent;
    color: #e74c3c;
    font-size: 16px;
    font-weight: bold;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-logout:hover {
    background-color: #e74c3c;
    color: white;
  }



  



