.form-footer a:hover {
  color: #564787;
  text-decoration: underline;
}*/
</style>

<div class="perfil-container">
  <h1>Meu Perfil</h1>
  
  <div class="avatar-container">
    <img id="perfil-foto-img" class="avatar-preview" src="https://cdn-icons-png.flaticon.com/512/149/149071.png" alt="Foto de Perfil">
  </div>

  <div class="foto-form">
    <input type="file" id="input-file-foto" accept="image/*" onchange="atualizarFotoLocal(this)">
    <label for="input-file-foto" class="label-upload">Escolher Foto</label>
  </div>
  
  <div class="info-box">
    <p><strong>Nome:</strong> <span id="perfil-nome">Carregando...</span></p>
  </div>
  
  <div class="info-box">
    <p><strong>Usuário:</strong> <span id="perfil-username">Carregando...</span></p>
  </div>
  
  <div class="info-box">
    <p><strong>E-mail:</strong> <span id="perfil-email">Carregando...</span></p>
  </div>

  <a href="/" class="btn-voltar">Voltar ao Início</a>
  <a href="/auth/logout" class="btn-logout" onclick="return fazerLogout(event)">Sair da Conta</a>
</div>

<script>
  function carregarPerfil() {
      const usuario = JSON.parse(localStorage.getItem("usuario"));
      
      if (!usuario) {
          alert("Você precisa estar logado para ver seu perfil!");
          window.location.href = "/login";
          return;
      }
      
      document.getElementById('perfil-nome').innerText = usuario.nome || "Não informado";
      document.getElementById('perfil-username').innerText = usuario.username ? `@${usuario.username}` : "Não informado";
      document.getElementById('perfil-email').innerText = usuario.email || "Não informado";
      
      if (usuario.fotoUrl) {
          document.getElementById('perfil-foto-img').src = usuario.fotoUrl;
      }
  }

  function atualizarFotoLocal(input) {
      if (input.files && input.files[0]) {
          const arquivo = input.files[0];

          if (arquivo.size > 2 * 1024 * 1024) { 
              alert("Escolha uma imagem de até 2MB para não sobrecarregar o sistema!");
              return;
          }

          const leitor = new FileReader();
          
          leitor.onload = function(e) {
              const base64String = e.target.result;
              const usuario = JSON.parse(localStorage.getItem("usuario"));
              if (usuario) {
                  usuario.fotoUrl = base64String;
                  localStorage.setItem("usuario", JSON.stringify(usuario));
                  document.getElementById('perfil-foto-img').src = base64String;
                  alert("Foto de perfil updated com sucesso!");
              }
          }
          
          leitor.readAsDataURL(arquivo);
      }
  }

  // 🌟 FUNÇÃO AJUSTADA: Limpa o front-end e permite o redirecionamento ao servidor para limpar a sessão
  function fazerLogout(event) {
      if (confirm("Tem certeza que deseja sair da conta?")) {
          // Limpa a sessão local e dados residuais do navegador
          localStorage.removeItem("usuario");
          sessionStorage.clear();
          
          alert("Sessão encerrada localmente! Redirecionando...");
          
          // Retorna true para permitir que o link avance até o servidor (/auth/logout)
          return true; 
      }
      
      // Cancela o clique caso o usuário mude de ideia no confirm
      event.preventDefault();
      return false;
  }

  window.addEventListener('DOMContentLoaded', carregarPerfil);
</script>

<%- include('partials/footer') %>