 <%- include('partials/header', { title: 'Postar trabalho' }) %>

<style>
body {
  background-attachment: fixed;
  background-size: cover;
  background-position: center;
  min-height: 100vh;
  margin: 0;
  padding: 0;
}

.titulo-principal {
  color: #564787;
  font-size: 40px;
  font-family: "Stencil Std", "Stencil", fantasy;
  letter-spacing: 1px;
  padding: 20px;
  padding-left: 1px;
  padding-top: 25px;
  box-sizing: border-box;
  text-align: center;
}

h2 {
  font-family: 'Georgia', serif;
  color: #564787;
  font-size: 28px;
  margin-top: 0;
  margin-bottom: 20px;
  text-align: center;
}

p{
  font-family: 'Georgia', serif;
  color: #564787;
  margin: 10px auto;
  margin-top: 35px;
  line-height: 1.5;
  font-size: 18px;
  font-weight: bold;
  text-align: left;
  max-width: 100%;
}

.bloco {
  width: 100%;
  max-width: 2000px;
  margin: 0 auto;
  background-color: #ad9fdd;
  display: flex;
  align-items: flex-start;
  border-radius: 8px;
  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
  padding-top: 10px;
  margin-top: -30px;
  padding: 0 20px;
  gap: 20px;
}

.home {
  min-height: auto;
}

.modal {
  display: none;
  background: rgba(0,0,0,0.5);
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100vh;
  overflow-y: auto;
  z-index: 9999;
}

.modal-content {
  background: #ad9fdd;
  width: 700px;
  max-width: 90%;
  margin: 60px auto;
  padding: 30px;
  border-radius: 20px;
  box-shadow: 0 8px 25px rgba(0,0,0,0.25);
}

.fechar {
  float: right;
  cursor: pointer;
  font-size: 35px;
  color: #564787;
  font-weight: bold;
}

input,
textarea {
  width: 100%;
  margin-bottom: 15px;
  padding: 12px;
  border: 2px solid #efeaff;
  border-radius: 10px;
  box-sizing: border-box;
  font-size: 16px;
  font-family: Georgia, serif;
}

.btn {
  padding: 15px 40px;
  background: #564787;
  color: #efeaff;
  border: none;
  border-radius: 12px;
  cursor: pointer;
  font-size: 20px;
  font-weight: bold;
  font-family: 'Georgia', serif;
  display: block;
  margin: 30px auto;
  transition: 0.2s;
}

.btn:hover {
  background: #45366f;
  transform: translateY(-2px);
}

.btn-publicar-modal {
  width: 100%;
  padding: 15px;
  background: #564787;
  color: #efeaff;
  border: none;
  border-radius: 10px;
  font-size: 18px;
  font-weight: bold;
  cursor: pointer;
}

.btn-publicar-modal:hover {
  background: #45366f;
}
</style>

<div class="main-content">
    <div class="bloco">
        <h2 class="titulo-principal">Postar trabalho</h2>
        <p>
            Poste aqui um de seus trabalhos para que outros usuários vejam!
        </p>
    </div>
</div>

<button class="btn" onclick="abrirModal()">Publicar</button>
<div id="modal" class="modal">
  <div class="modal-content">
    <span class="fechar" onclick="fecharModal()">&times;</span>

    <h2>Novo Trabalho</h2>

    <form action="/publishworks" method="POST">
      <input
        type="text"
        name="titulo"
        placeholder="Título do trabalho"
        required
      >

      <textarea
      name="descricao"
      rows="3"
      placeholder="Descrição resumida do trabalho"
      required
      ></textarea>
      
      <textarea
      name="historia"
      rows="12"
      placeholder="Escreva sua história completa aqui..."
      required
      ></textarea>

      <input type="hidden" name="autor" id="autor">

      <button type="submit" class="btn-publicar-modal">Publicar Trabalho</button>
    </form>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const usuario = JSON.parse(localStorage.getItem('usuario'));

  console.log('Usuário salvo:', usuario);

  if (usuario) {
    document.getElementById('autor').value =
      usuario.username || usuario.nome || usuario.email;
  }
});
</script>

<script src="/javascripts/publishworks.js"></script>

<%- include('partials/footer') %>