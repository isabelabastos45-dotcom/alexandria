<%- include('partials/header', { title: 'Signup' }) %>

<style>
body {
  background-attachment: fixed;
  background-size: cover;
  background-position: center;
  min-height: 100vh;
  margin: 0;
  padding: 0;
}

.titulo-principal {
  color: #564787;
  font-size: 30px;
  font-family: "Stencil Std", "Stencil", fantasy;
  letter-spacing: 1px;
  padding: 20px;
  padding-left: 1px;
  padding-top: 30px;
  padding-bottom: -30px;
  box-sizing: border-box;
  text-align: center;
} 

h2 {
  font-family: 'Georgia', serif;
  color: #564787;
  font-size: 28px;
  margin-top: 0;
  margin-bottom: 20px;
  text-align: center;
}

p{
  font-family: 'Georgia', serif;
  color: #564787;
  margin: 10px auto;
  margin-top: 22px;
  line-height: 1.5;
  font-size: 18px;
  font-weight: bold;
  text-align: left;
  max-width: 100%;
}

.bloco {
  width: 100%;
  max-width: 400px;
  margin: 20px auto 10px auto;
  background-color: #ad9fdd;
  border-radius: 8px;
  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
  padding: 10px 15px;
  display: flex;
  justify-content: center;
  align-items: center;
}

.home {
  min-height: auto;
}

.form-container {
  background: #ad9fdd; 
  padding: 40px;
  border-radius: 8px;
  width: 100%;
  max-width: 400px; 
  margin: 30px auto 100px auto; 
  box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  display: flex;
  flex-direction: column;
  gap: 20px;
  box-sizing: border-box;
  font-family: 'Georgia', serif;
}

#form {
  display: flex;
  flex-direction: column;
  gap: 15px;
}

#form input {
  width: 100%;
  padding: 15px;
  border: 1px solid #564787;
  border-radius: 8px;
  font-size: 16px;
  box-sizing: border-box;
  transition: border-color 0.3s ease;
  font-family: 'Georgia', serif;
}

#form input:focus {
  border-color: #564787;
  outline: none;
}

#form button {
  padding: 15px 25px;
  border: none;
  border-radius: 8px;
  color: #efeaff ; 
  font-size: 18px;
  cursor: pointer;
  background-color: #564787;
  font-weight: bold;
  transition: background 0.2s ease;
  font-family: 'Georgia', serif;
}

#form button:hover {
  background-color: #33255f;
}

.form-footer {
  text-align: center;
  margin-top: 10px;
  font-size: 16px;
  color: #564787;
  font-weight: bold;
}

.form-footer a {
  color: #33255f;
  text-decoration: underline;
  transition: color 0.2s;
}

.form-footer a:hover {
  color: #564787;
  text-decoration: underline;
}
</style>

<div class="bloco">
    <h2 class="titulo-principal">Inscreva-se</h2>
  </div>

<div class="form-container">
  <form id="form">
    <input type="text" id="username" placeholder="Nome de usuário" required minlength="3" pattern="^[a-zA-Z0-9_.]+$" title="Apenas letras, números, pontos ou underlines." />
    <input type="email" id="email" placeholder="Email válido" required />
    <input type="password" id="senha" placeholder="Senha (Mínimo 6 caracteres)" required minlength="6" />

    <button type="submit">Criar minha conta</button>
  </form>

  <div class="form-footer">
    Já tem uma conta? <a href="/login">Entre aqui</a>
  </div>
</div>

<script>
document.getElementById("form").addEventListener("submit", async (e) => {
  e.preventDefault();

  const username = document.getElementById("username").value.trim();
  const email = document.getElementById("email").value.trim();
  const senha = document.getElementById("senha").value;

  if (senha.length < 6) {
    alert("A senha precisa ter no mínimo 6 caracteres!");
    return;
  }

  try {
    const URL_BASE = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1'
      ? 'http://localhost:3000'
      : 'https://alexandria-nkt3.onrender.com';

    const resposta = await fetch(`${URL_BASE}/auth/register`, {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({ username, email, senha })
    });

    const dados = await resposta.json();

    if (resposta.ok) {
      alert(dados.msg || "Cadastro realizado com sucesso!");
      document.getElementById("form").reset();
      window.location.href = "/login";
    } else {
      alert(dados.msg || "Erro ao realizar o cadastro.");
    }

  } catch (error) {
    console.error(error);
    alert("Erro de conexão com o servidor!");
  }
});
</script>

<%- include('partials/footer') %>