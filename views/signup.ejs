<%- include('partials/header', { title: 'Signup' }) %>

<link href="https://fonts.googleapis.com/css2?family=Merriweather:wght=900&display=swap" rel="stylesheet">

<style>
body {
  background: linear-gradient(180deg, #74b9ff 0%, #dfefff 60%, #ffffff 100%);
  background-attachment: fixed; 
  min-height: 100vh;
  margin: 0;
  padding: 0;
  font-family: sans-serif;
}

h2,
p {
  text-align: center;
}

h2 {
  font-size: 40px; 
  color: #6dbdff;
  font-family: 'Merriweather', serif;
  font-weight: 1000;
  letter-spacing: 1px;
  padding: 20px;
  background-color: #104488;
  width: fit-content;
  max-width: 100vw;
  margin: 0 auto 30px auto;
  border-radius: 20px;
}

p {
  max-width: 750px;
  margin: 15px auto;
  line-height: 1.6;
  font-size: 18px;
  color: #000000;
  font-weight: bold;
}

.hero {
  padding-top: 40px;
  padding-left: 20px;
  padding-right: 20px;
}

.form-container {
  background: rgba(255, 255, 255, 0.85); 
  padding: 40px;
  border-radius: 25px;
  width: 100%;
  max-width: 500px; 
  margin: 15px auto 100px auto; 
  box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  box-sizing: border-box;
}

#form {
  display: flex;
  flex-direction: column;
  gap: 15px;
}

#form input {
  width: 100%;
  padding: 15px;
  border: 1px solid #ccc;
  border-radius: 8px;
  font-size: 16px;
  box-sizing: border-box;
  background-color: #ffffff;
  transition: border-color 0.3s;
}

#form input:focus {
  border-color: #007bff;
  outline: none;
}

#form button {
  padding: 15px 25px;
  border: none;
  border-radius: 8px;
  color: white; 
  font-size: 18px;
  cursor: pointer;
  background-color: #007bff;
  font-weight: bold;
  transition: background-color 0.3s;
  width: 100%;
}

#form button:hover {
  background-color: #0056b3;
}

.form-footer {
  text-align: center;
  margin-top: 20px;
  font-size: 16px;
  color: #333;
  font-weight: bold;
}

.form-footer a {
  color: #007bff;
  text-decoration: none;
  transition: color 0.2s;
}

.form-footer a:hover {
  color: #0056b3;
  text-decoration: underline;
}
</style>

<section class="hero">
  <div class="container">
    <h2>Formulário para inscrição</h2>
  </div>

  <p>
    Por que criar sua conta na Fixly?<br>
    Junte-se a nós e tenha acesso a uma experiência sob medida para você. Ao se inscrever, você garante:
  </p>
  <p>
    ✓ Acesso Exclusivo: Recursos e ferramentas disponíveis apenas para membros.<br>
    ✓ Histórico Completo: Salve suas preferências, acompanhe suas atividades e não perca nenhum detalhe.<br>
    ✓ Segurança e Praticidade: Um ambiente seguro com logins rápidos para facilitar o seu dia a dia.
  </p>
  <p>
    Leva menos de 1 minuto! Preencha os campos abaixo e comece agora.
  </p>
</section>

<div class="form-container">
  <form id="form">
    <input type="text" id="nome" placeholder="Nome completo" required minlength="3" />
    <input type="text" id="username" placeholder="Nome de usuário" required minlength="3" pattern="^[a-zA-Z0-9_.]+$" title="Apenas letras, números, pontos ou underlines." />
    <input type="email" id="email" placeholder="Email válido" required />
    <input type="password" id="senha" placeholder="Senha (Mínimo 6 caracteres)" required minlength="6" />

    <button type="submit">Criar minha conta</button>
  </form>

  <div class="form-footer">
    Já tem uma conta? <a href="/login">Entre aqui</a>
  </div>
</div>

<script>
document.getElementById("form").addEventListener("submit", async (e) => {
  e.preventDefault();

  const nome = document.getElementById("nome").value.trim();
  const username = document.getElementById("username").value.trim();
  const email = document.getElementById("email").value.trim();
  const senha = document.getElementById("senha").value;

  // Validação extra básica via JS no front antes de enviar
  if (senha.length < 6) {
    alert("A senha precisa ter no mínimo 6 caracteres!");
    return;
  }

  try {
    // 1. Identifica onde o site está rodando e define o endereço base do servidor
    const URL_BASE = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1'
      ? 'http://localhost:3000'
      : 'https://fixly-o7l5.onrender.com'; // Removida a barra do final para não duplicar na rota

    // 2. Faz a requisição usando a variável dinâmica
    const resposta = await fetch(`${URL_BASE}/auth/register`, {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({ nome, username, email, senha })
    });

    const dados = await resposta.json();

    if (resposta.ok) {
      alert(dados.msg || "Cadastro realizado com sucesso!");
      document.getElementById("form").reset();
      window.location.href = "/login"; // Redireciona para o login
    } else {
      // Exibe a mensagem de erro específica vinda do servidor (ex: "Username já existe")
      alert(dados.msg || "Erro ao realizar o cadastro.");
    }

  } catch (error) {
    console.error(error);
    alert("Erro de conexão com o servidor!");
  }
});
</script>

<%- include('partials/footer') %>