<%- include('partials/header', { title: 'Trabalhos' }) %>

<style>
body {
  background-attachment: fixed;
  background-size: cover;
  background-position: center;
  min-height: 100vh;
  margin: 0;
  padding: 0;
}

.titulo-principal {
  color: #564787;
  font-size: 40px;
  font-family: "Stencil Std", "Stencil", fantasy;
  letter-spacing: 1px;
  padding: 20px;
  padding-left: 1px;
  padding-top: 25px;
  box-sizing: border-box;
  text-align: center;
}

h2 {
  font-family: 'Georgia', serif;
  color: #564787;
  font-size: 28px;
  margin-top: 0;
  margin-bottom: 20px;
  text-align: center;
}

p{
  font-family: 'Georgia', serif;
  color: #564787;
  margin: 10px auto;
  margin-top: 22px;
  line-height: 1.5;
  font-size: 18px;
  font-weight: bold;
  text-align: left;
  max-width: 100%;
}

.bloco {
  width: 100%;
  max-width: 2000px;
  margin: 0 auto;
  background-color: #ad9fdd;
  display: flex;
  align-items: flex-start;
  border-radius: 8px;
  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
  padding-top: 10px;
  margin-top: -30px;
  padding: 0 20px;
  gap: 20px;
}

.home {
  min-height: auto;
}

.lista-trabalhos {
  max-width: 1000px;
  margin: 40px auto;
  padding: 0 20px;
}

.card-trabalho {
  background: #ad9fdd;
  border-radius: 15px;
  padding: 25px;
  margin-bottom: 25px;
  box-shadow: 0 4px 15px rgba(0,0,0,0.1);
  transition: 0.2s;
}

.card-trabalho:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 20px rgba(0,0,0,0.15);
}

.card-trabalho h3 {
  color: #564787;
  font-family: Georgia, serif;
  margin-top: 0;
  margin-bottom: 15px;
  font-size: 28px;
}

.card-trabalho p {
  color: #444;
  font-size: 17px;
  line-height: 1.6;
  margin: 0;
}

.trabalho-autor {
  color: #ffffff;
  font-size: 14px;
  margin-bottom: 10px;
}

.btn-ler {
  display: inline-block;
  margin-top: 20px;
  background: #564787;
  color: white;
  text-decoration: none;
  padding: 10px 20px;
  border-radius: 8px;
  font-weight: bold;
}

.btn-ler:hover {
  background: #45366f;
}

.trabalho-autor {
  color: #ffffff;
  font-size: 14px;
  margin-bottom: 10px;
}

.barra-pesquisa {
  display: flex;
  justify-content: center;
  gap: 10px;
  margin: 20px 0;
}

.barra-pesquisa input {
  width: 400px;
  padding: 10px;
  border: 2px solid #564787;
  border-radius: 8px;
}

.barra-pesquisa button {
  padding: 10px 20px;
  background: #564787;
  color: white;
  border: none;
  border-radius: 8px;
  cursor: pointer;
}
</style>

<div class="main-content">
    <div class="bloco">
        <h2 class="titulo-principal">Trabalhos</h2>
        <p>
            Aqui se encontram todos os trabalhos feitos para Alexandria, utilize a barra de pesquisa e os filtros para uma melhor experiência.
        </p>
    </div>
</div>

<form action="/works" method="GET" class="barra-pesquisa">
  <input
    type="text"
    name="q"
    placeholder="Pesquisar trabalho..."
    value="<%= pesquisa || '' %>"
  >
  <button type="submit">Pesquisar</button>
</form>

<div class="main-content">
  <h2>Trabalhos postados</h2>
  
  <div class="lista-trabalhos">
    <% trabalhos.forEach(trabalho => { %>
      <div class="card-trabalho">
        <div class="trabalho-autor">Publicado por <%= trabalho.autor %></div>
        <h3><%= trabalho.titulo %></h3>
        <p><%= trabalho.descricao %></p>
        <a href="/works/<%= trabalho._id %>" class="btn-ler">Ler trabalho</a>
      </div>
      <% }) %>
    </div>
  </div>

<%- include('partials/footer') %>